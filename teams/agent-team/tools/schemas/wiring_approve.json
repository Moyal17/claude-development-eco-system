{
  "name": "wiring_approve",
  "description": "Approve the implementation from an end-to-end wiring and production-readiness perspective. Only callable by wiring_expert. A complete trace object is required even on approval.",
  "input_schema": {
    "type": "object",
    "required": ["task_id", "revision", "summary", "trace"],
    "properties": {
      "task_id": { "type": "string", "pattern": "^TASK-[0-9]+$" },
      "revision": { "type": "integer", "minimum": 1 },
      "summary": { "type": "string", "description": "One sentence confirming the feature is wired end-to-end and production-ready" },
      "trace": {
        "type": "object",
        "required": ["entrypoint", "path", "terminal"],
        "properties": {
          "entrypoint": { "type": "string" },
          "path": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "terminal": { "type": "string" }
        }
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["category", "file", "note"],
          "properties": {
            "category": { "type": "string", "enum": ["entrypoint", "dependency", "schema", "dead_code", "regression", "production_readiness"] },
            "file": { "type": "string" },
            "line": { "type": "string" },
            "note": { "type": "string" }
          }
        },
        "default": []
      }
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "gate": { "type": "string", "const": "wiring_approval" },
      "approved": { "type": "boolean", "const": true },
      "task_id": { "type": "string" }
    }
  }
}
