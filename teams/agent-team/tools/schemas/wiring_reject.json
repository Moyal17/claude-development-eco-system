{
  "name": "wiring_reject",
  "description": "Reject the implementation due to broken wiring, dead code, regressions, or production-readiness failures. Only callable by wiring_expert. A trace block is required to prove the review was done. Sends the task back to FIX_IN_PROGRESS.",
  "input_schema": {
    "type": "object",
    "required": ["task_id", "revision", "summary", "trace", "findings"],
    "properties": {
      "task_id": { "type": "string", "pattern": "^TASK-[0-9]+$" },
      "revision": { "type": "integer", "minimum": 1 },
      "summary": { "type": "string", "description": "One sentence overall rejection reason" },
      "trace": {
        "type": "object",
        "description": "Partial or complete trace showing where the connection breaks",
        "required": ["entrypoint", "path"],
        "properties": {
          "entrypoint": { "type": "string" },
          "path": { "type": "array", "items": { "type": "string" } },
          "terminal": { "type": "string", "description": "Omit if trace could not be completed due to broken wiring" },
          "break_point": { "type": "string", "description": "file:line where the trace breaks or goes dead" }
        }
      },
      "findings": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["severity", "category", "file", "issue", "fix"],
          "properties": {
            "severity": { "type": "string", "enum": ["blocking", "warning"] },
            "category": { "type": "string", "enum": ["entrypoint", "dependency", "schema", "dead_code", "regression", "production_readiness"] },
            "file": { "type": "string" },
            "line": { "type": "string" },
            "issue": { "type": "string", "minLength": 10 },
            "fix": { "type": "string", "minLength": 10 }
          }
        }
      }
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "gate": { "type": "string", "const": "wiring_approval" },
      "rejected": { "type": "boolean", "const": true },
      "task_id": { "type": "string" },
      "new_task_status": { "type": "string", "const": "FIX_IN_PROGRESS" }
    }
  }
}
