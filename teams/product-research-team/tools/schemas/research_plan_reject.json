{
  "name": "research_plan_reject",
  "description": "CPO rejects a researcher's research plan and returns it for revision. The researcher must revise and resubmit. Only the CPO may call this tool.",
  "input_schema": {
    "type": "object",
    "required": ["brief_id", "researcher_id", "plan_version", "summary", "blocking_concerns"],
    "properties": {
      "brief_id": {
        "type": "string",
        "pattern": "^BRIEF-[0-9]+$"
      },
      "researcher_id": {
        "type": "string",
        "enum": ["researcher_1", "researcher_2"]
      },
      "plan_version": {
        "type": "string",
        "description": "The plan_version timestamp being rejected"
      },
      "summary": {
        "type": "string",
        "description": "One sentence explaining why the plan is rejected",
        "minLength": 15
      },
      "blocking_concerns": {
        "type": "array",
        "description": "All concerns the researcher must address before resubmission",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["area", "detail", "suggested_fix"],
          "properties": {
            "area": { "type": "string", "description": "Area of the plan with the issue" },
            "detail": { "type": "string", "description": "Specific problem" },
            "suggested_fix": { "type": "string", "description": "What must change" }
          }
        }
      }
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "rejected": { "type": "boolean", "const": true },
      "gate": { "type": "string", "const": "research_plan_approval" },
      "decided_at": { "type": "string", "format": "date-time" }
    }
  }
}
